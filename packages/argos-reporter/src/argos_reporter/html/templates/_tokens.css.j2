/*
 * Inline copy of design-system/tokens.css so reports render without external
 * requests. Kept in sync by the reporter's build step; never edited by hand.
 */
:root {
  --argos-color-green-600: #059669;
  --argos-color-green-700: #047857;
  --argos-color-green-500: #10b981;
  --argos-color-green-400: #34d399;
  --argos-color-green-100: #d1fae5;
  --argos-color-green-50:  #ecfdf5;

  --argos-color-ink-950: #030712;
  --argos-color-ink-900: #111827;
  --argos-color-ink-800: #1f2937;
  --argos-color-ink-700: #374151;
  --argos-color-ink-500: #6b7280;
  --argos-color-ink-300: #d1d5db;
  --argos-color-ink-200: #e5e7eb;
  --argos-color-ink-100: #f3f4f6;
  --argos-color-ink-50:  #f9fafb;
  --argos-color-paper:   #ffffff;

  --argos-sev-critical: #991b1b;
  --argos-sev-high:     #c2410c;
  --argos-sev-medium:   #a16207;
  --argos-sev-low:      #365314;
  --argos-sev-info:     #1e40af;

  --argos-font-sans: Inter, ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
  --argos-font-mono: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;

  --argos-fs-xs:   0.75rem;
  --argos-fs-sm:   0.875rem;
  --argos-fs-base: 1rem;
  --argos-fs-lg:   1.125rem;
  --argos-fs-xl:   1.25rem;
  --argos-fs-2xl:  1.5rem;
  --argos-fs-3xl:  1.875rem;
  --argos-fs-4xl:  2.25rem;

  --argos-sp-1: 0.25rem;
  --argos-sp-2: 0.5rem;
  --argos-sp-3: 0.75rem;
  --argos-sp-4: 1rem;
  --argos-sp-6: 1.5rem;
  --argos-sp-8: 2rem;
  --argos-sp-12: 3rem;
  --argos-sp-16: 4rem;

  --argos-radius-sm: 4px;
  --argos-radius-md: 6px;
  --argos-radius-lg: 8px;

  --argos-shadow-sm: 0 1px 3px rgba(0,0,0,0.06), 0 1px 2px rgba(0,0,0,0.04);

  --argos-max-content: 72rem;
  --argos-max-prose:   40rem;
}
