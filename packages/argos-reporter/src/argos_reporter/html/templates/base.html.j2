<!doctype html>
<html lang="{{ lang | default('en') }}" data-theme="{{ theme | default('light') }}">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="referrer" content="no-referrer" />
    <meta name="generator" content="ARGOS v{{ generator_version | default('0.0.0') }}" />
    <meta http-equiv="Content-Security-Policy" content="default-src 'none'; style-src 'unsafe-inline'; img-src data:; font-src data:; base-uri 'none'; form-action 'none'; frame-ancestors 'none';" />
    <meta http-equiv="X-Content-Type-Options" content="nosniff" />
    <title>{% block title %}ARGOS Report{% endblock %}</title>

    <style>
      {% include "_reset.css.j2" %}
      {% include "_tokens.css.j2" %}
      {% include "_base.css.j2" %}
      {% include "_report.css.j2" %}
      {% block head_styles %}{% endblock %}
    </style>
    {% block head_extra %}{% endblock %}
  </head>
  <body>
    {% block chrome_header %}
    <header class="argos-header">
      <div class="argos-container argos-row argos-between">
        <div class="argos-brand" aria-label="ARGOS">
          <span class="argos-brand-mark" aria-hidden="true"></span>
          <span class="argos-brand-text">ARGOS</span>
        </div>
        <div class="argos-header-meta">
          {% block header_meta %}
            Generated {{ generated_at | default('') }}
          {% endblock %}
        </div>
      </div>
    </header>
    {% endblock %}

    <main class="argos-container argos-main">
      {% block content %}{% endblock %}
    </main>

    {% block chrome_footer %}
    <footer class="argos-footer">
      <div class="argos-container argos-row argos-between">
        <span>ARGOS v{{ generator_version | default('0.0.0') }}</span>
        <span>AGPL-3.0-or-later &middot; open source</span>
      </div>
    </footer>
    {% endblock %}

    {% block body_scripts %}{% endblock %}
  </body>
</html>
