{
  "$schema": "./tokens.schema.json",
  "meta": {
    "name": "ARGOS Design System",
    "version": "0.1.0",
    "description": "Design tokens (single source of truth). Consumed by tokens.css, tokens.py, tokens.ts via scripts/build-tokens.py.",
    "reference": "greenlock.tech",
    "updated": "2026-04-15"
  },
  "color": {
    "green": {
      "50":  { "value": "#ecfdf5", "usage": "Subtle success backgrounds, active code blocks" },
      "100": { "value": "#d1fae5", "usage": "Activation-subtle backgrounds" },
      "400": { "value": "#34d399", "usage": "Decorative, subtle highlights, dark-mode accent" },
      "500": { "value": "#10b981", "usage": "CTA hover, accents" },
      "600": { "value": "#059669", "usage": "Brand primary (logo, CTAs)" },
      "700": { "value": "#047857", "usage": "Text emphasis, active links" },
      "900": { "value": "#064e3b", "usage": "Headings on light" }
    },
    "ink": {
      "50":  { "value": "#f9fafb", "usage": "Alternate page background" },
      "100": { "value": "#f3f4f6", "usage": "Zone backgrounds (cards, tables)" },
      "200": { "value": "#e5e7eb", "usage": "Dividers, default borders" },
      "300": { "value": "#d1d5db", "usage": "Subtle borders, hover borders" },
      "400": { "value": "#9ca3af", "usage": "Disabled text, light-mode footers" },
      "500": { "value": "#6b7280", "usage": "Tertiary text, placeholders" },
      "700": { "value": "#374151", "usage": "Secondary dark text" },
      "800": { "value": "#1f2937", "usage": "Secondary dark background, strong borders" },
      "900": { "value": "#111827", "usage": "Primary dark background" },
      "950": { "value": "#030712", "usage": "Maximum-contrast text on light" }
    },
    "paper":    { "value": "#ffffff", "usage": "Primary light background" },
    "night":    { "value": "#0a0e17", "usage": "Report cover dark header; near-black navy with slight blue" },
    "midnight": { "value": "#1a1a2e", "usage": "Report body title / heading text on paper" },
    "severity": {
      "critical": { "value": "#7030A0", "usage": "Critical badge (CVSS >= 9.0); purple as in Greenlock report convention" },
      "high":     { "value": "#E53E3E", "usage": "High badge (CVSS 7.0-8.9)" },
      "medium":   { "value": "#F6AD55", "usage": "Medium badge (CVSS 4.0-6.9)" },
      "low":      { "value": "#F6E05E", "usage": "Low badge (CVSS < 4.0)" },
      "info":     { "value": "#C6F6D5", "usage": "Informational badge (pale green)" }
    }
  },
  "typography": {
    "family": {
      "sans": {
        "value": "Inter, ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial, sans-serif",
        "usage": "UI, body"
      },
      "mono": {
        "value": "\"JetBrains Mono\", ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, \"Liberation Mono\", \"Courier New\", monospace",
        "usage": "Code, hashes, CVEs, paths"
      }
    },
    "size": {
      "xs":   { "value": "0.75rem",  "px": 12, "line-height": 1.5 },
      "sm":   { "value": "0.875rem", "px": 14, "line-height": 1.5 },
      "base": { "value": "1rem",     "px": 16, "line-height": 1.6 },
      "lg":   { "value": "1.125rem", "px": 18, "line-height": 1.5 },
      "xl":   { "value": "1.25rem",  "px": 20, "line-height": 1.4 },
      "2xl":  { "value": "1.5rem",   "px": 24, "line-height": 1.3 },
