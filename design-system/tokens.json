      "4xl":  { "value": "2.25rem",  "px": 36, "line-height": 1.2 },
      "5xl":  { "value": "3rem",     "px": 48, "line-height": 1.1 }
    },
    "weight": {
      "regular":  { "value": 400 },
      "medium":   { "value": 500 },
      "semibold": { "value": 600 },
      "bold":     { "value": 700 }
    }
  },
  "spacing": {
    "0":  { "value": "0" },
    "1":  { "value": "0.25rem", "px": 4 },
    "2":  { "value": "0.5rem",  "px": 8 },
    "3":  { "value": "0.75rem", "px": 12 },
    "4":  { "value": "1rem",    "px": 16 },
    "6":  { "value": "1.5rem",  "px": 24 },
    "8":  { "value": "2rem",    "px": 32 },
    "12": { "value": "3rem",    "px": 48 },
    "16": { "value": "4rem",    "px": 64 },
    "24": { "value": "6rem",    "px": 96 }
  },
  "layout": {
    "max-width-content": { "value": "72rem",  "px": 1152 },
    "max-width-prose":   { "value": "40rem",  "px": 640 }
  },
  "radius": {
    "sm":   { "value": "4px" },
    "md":   { "value": "6px" },
    "lg":   { "value": "8px" },
    "xl":   { "value": "12px" },
    "full": { "value": "9999px" }
  },
  "shadow": {
    "xs": { "value": "0 1px 2px rgba(0,0,0,0.04)" },
    "sm": { "value": "0 1px 3px rgba(0,0,0,0.06), 0 1px 2px rgba(0,0,0,0.04)" },
    "md": { "value": "0 4px 6px rgba(0,0,0,0.05), 0 2px 4px rgba(0,0,0,0.04)" }
  },
  "motion": {
    "duration": {
      "fast":   { "value": "120ms" },
      "normal": { "value": "200ms" }
    },
    "easing": {
      "out": { "value": "cubic-bezier(0.16, 1, 0.3, 1)" }
    }
  }
}
